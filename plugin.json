{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-sidebar-sky",
  "name": {
    "ko": "창밖 풍경",
    "en": "Window"
  },
  "version": "0.0.1",
  "description": {
    "ko": "좌측 사이드바 하단의 창밖 풍경 — 시간대에 따라 변하고, 나무가 흔들리고 낮엔 구름이 흐르며 밤엔 별이 반짝인다.",
    "en": "A window to the sky in the left sidebar — shifts with the time of day; trees sway, clouds drift by day, stars twinkle at night."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "commands"
  ],
  "contributes": {
    "views": [
      {
        "id": "panel",
        "title": {
          "ko": "창밖 풍경",
          "en": "Window"
        },
        "icon": "☼",
        "placements": [
          "rail-footer"
        ],
        "resident": true
      }
    ],
    "nodes": [
      {
        "id": "cycle",
        "description": {
          "ko": "창밖 풍경(클릭=시간대 순환 day→sunset→dusk→night→자동)",
          "en": "The window scene (click = cycle time of day day→sunset→dusk→night→auto)"
        }
      }
    ],
    "commands": [
      {
        "name": "state",
        "title": {
          "ko": "현재 시간대 상태",
          "en": "Time-of-day state"
        }
      },
      {
        "name": "set",
        "title": {
          "ko": "시간대 강제/복귀",
          "en": "Force / clear phase"
        }
      }
    ]
  }
}
